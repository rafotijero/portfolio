---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/BlogCard.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout
	title="Blog — Rafael Tijero Fuentes"
	description="Notas sobre backend con Java y Spring Boot, arquitectura de software e interoperabilidad en el sector público."
>
	<Header />
	<main>
		<section class="mx-auto max-w-5xl px-6 py-16">
			<h1 class="text-gradient text-3xl font-semibold tracking-tight md:text-4xl">Blog</h1>
			<p class="mt-3 max-w-xl text-muted-fg">
				Notas técnicas sobre backend con Java y Spring Boot, arquitectura de software e
				interoperabilidad en el sector público.
			</p>
			<div class="mt-10 grid gap-4 sm:grid-cols-2">
				{posts.map((post) => <BlogCard post={post} />)}
			</div>
		</section>
	</main>
	<Footer />
</Layout>
