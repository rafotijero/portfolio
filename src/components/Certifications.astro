---
import { certifications, additionalTraining } from '../data/certifications';
import LogoAvatar from './LogoAvatar.astro';
---

<section id="certificaciones" class="reveal mx-auto max-w-5xl px-6 py-16">
	<h2 class="font-mono text-sm text-accent-2">04. Certificaciones</h2>

	<div class="mt-6 grid gap-4 sm:grid-cols-2">
		{
			certifications.map((cert) => (
				<div class="flex items-start gap-3 rounded-lg border border-border bg-card p-4">
					<LogoAvatar name={cert.institution} logo={cert.logo} size="size-10" />
					<div>
						<p class="text-fg">{cert.name}</p>
						<p class="mt-1 text-sm text-muted-fg">{cert.institution}</p>
						<p class="mt-2 font-mono text-xs text-accent-2">
							{cert.hours} · {cert.year}
						</p>
					</div>
				</div>
			))
		}
	</div>

	<p class="mt-6 text-sm text-muted-fg">
		<span class="text-fg/80">Formación adicional:</span> {additionalTraining}
	</p>
</section>
