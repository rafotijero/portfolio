---
import type { CollectionEntry } from 'astro:content';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const formatted = pubDate.toLocaleDateString('es-PE', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
	timeZone: 'UTC',
});
---

<a
	href={`/blog/${post.id}/`}
	class="group block rounded-lg border border-border bg-card p-5 transition-colors hover:border-accent-2"
>
	<p class="font-mono text-xs text-muted-fg">{formatted}</p>
	<h3 class="mt-2 text-lg font-medium text-fg transition-colors group-hover:text-accent-2">
		{title}
	</h3>
	<p class="mt-2 text-sm text-fg/80">{description}</p>
	{
		tags.length > 0 && (
			<div class="mt-4 flex flex-wrap gap-2">
				{tags.map((tag) => (
					<span class="rounded-md border border-border bg-muted px-2 py-0.5 font-mono text-xs text-accent-2">
						{tag}
					</span>
				))}
			</div>
		)
	}
</a>
