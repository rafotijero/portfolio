---
import { site } from '../data/site';

const items = [
	{
		href: '/',
		label: 'Inicio',
		path: '<path d="M4 11.5 12 4l8 7.5" stroke-linecap="round" stroke-linejoin="round" /><path d="M6 10v9a1 1 0 0 0 1 1h3v-5a2 2 0 0 1 4 0v5h3a1 1 0 0 0 1-1v-9" stroke-linecap="round" stroke-linejoin="round" />',
	},
	{
		href: '/blog',
		label: 'Blog',
		path: '<path d="M5 4h9l5 5v11a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1Z" stroke-linejoin="round" /><path d="M14 4v5h5M8 13h8M8 17h5" stroke-linecap="round" />',
	},
	{
		href: site.github,
		label: 'GitHub',
		external: true,
		path: '<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" fill="currentColor" stroke="none" />',
	},
	{
		href: site.linkedin,
		label: 'LinkedIn',
		external: true,
		path: '<rect x="3" y="9" width="4" height="12" rx=".5" /><circle cx="5" cy="4.5" r="2" /><path d="M11 21V9h4v1.8c.7-1.1 1.9-2 3.6-2 2.8 0 4.4 1.9 4.4 5.2V21h-4v-6c0-1.5-.6-2.5-2-2.5s-2.2 1-2.2 2.5v6z" />',
	},
	{
		href: `mailto:${site.email}`,
		label: 'Email',
		path: '<rect x="3" y="5" width="18" height="14" rx="2" /><path d="m4 7 8 6 8-6" stroke-linecap="round" stroke-linejoin="round" />',
	},
	{
		href: site.cvHref,
		label: 'Descargar CV',
		download: true,
		path: '<path d="M12 3v12m0 0-4-4m4 4 4-4" stroke-linecap="round" stroke-linejoin="round" /><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" stroke-linecap="round" stroke-linejoin="round" />',
	},
];
---

<nav
	class="fixed bottom-6 left-1/2 z-50 flex -translate-x-1/2 items-center gap-1 rounded-full border border-border bg-card/90 p-1.5 shadow-lg backdrop-blur supports-[backdrop-filter]:bg-card/70"
	aria-label="Navegación rápida"
>
	{
		items.map((item) => (
			<a
				href={item.href}
				title={item.label}
				aria-label={item.label}
				target={item.external ? '_blank' : undefined}
				rel={item.external ? 'noopener noreferrer' : undefined}
				download={item.download ? '' : undefined}
				class="group flex size-10 items-center justify-center rounded-full text-fg/70 transition-all hover:-translate-y-0.5 hover:bg-muted hover:text-fg"
			>
				<svg
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.8"
					class="size-5"
					set:html={item.path}
				/>
			</a>
		))
	}

	<span class="mx-1 h-6 w-px bg-border" />

	<button
		type="button"
		data-theme-toggle
		title="Cambiar tema"
		aria-label="Cambiar entre modo claro y oscuro"
		class="flex size-10 items-center justify-center rounded-full text-fg/70 transition-all hover:-translate-y-0.5 hover:bg-muted hover:text-fg"
	>
		<svg
			data-icon="sun"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="1.8"
			class="size-5"
		>
			<circle cx="12" cy="12" r="4" />
			<path
				d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
				stroke-linecap="round"
			/>
		</svg>
		<svg
			data-icon="moon"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="1.8"
			class="size-5"
		>
			<path d="M20 14.5A8.5 8.5 0 1 1 9.5 4a7 7 0 0 0 10.5 10.5Z" stroke-linejoin="round" />
		</svg>
	</button>
</nav>
