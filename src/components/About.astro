---
import { aboutParagraphs } from '../data/about';
import { education } from '../data/certifications';
import { languages } from '../data/skills';
import LogoAvatar from './LogoAvatar.astro';
---

<section id="sobre-mi" class="reveal mx-auto max-w-5xl px-6 py-16">
	<h2 class="font-mono text-sm text-accent-2">01. Sobre mí</h2>

	<div class="mt-6 grid gap-10 md:grid-cols-3">
		<div class="space-y-4 text-fg/90 md:col-span-2">
			{aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)}
		</div>

		<div class="space-y-6">
			<div>
				<h3 class="text-sm font-medium text-muted-fg">Educación</h3>
				<ul class="mt-3 space-y-3">
					{
						education.map((edu) => (
							<li class="flex items-start gap-3 text-sm">
								<LogoAvatar name={edu.institution} logo={edu.logo} size="size-9" class="mt-0.5" />
								<div>
									<p class="text-fg">{edu.degree}</p>
									<p class="text-muted-fg">{edu.institution}</p>
									<p class="font-mono text-xs text-muted-fg">{edu.note}</p>
								</div>
							</li>
						))
					}
				</ul>
			</div>

			<div>
				<h3 class="text-sm font-medium text-muted-fg">Idiomas</h3>
				<ul class="mt-3 flex flex-wrap gap-2">
					{
						languages.map((lang) => (
							<li class="rounded-md border border-border px-2 py-1 font-mono text-xs text-fg/80">
								{lang.name} · {lang.level}
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</div>
</section>
