---
import { skills } from '../data/skills';
import TechIcon from './icons/TechIcon.astro';

const allItems = skills.flatMap((group) => group.items);
---

<section id="stack" class="reveal mx-auto max-w-5xl px-6 py-16">
	<h2 class="font-mono text-sm text-accent-2">02. Stack técnico</h2>

	<div class="mt-6 overflow-hidden rounded-lg border border-border bg-card/50 py-4">
		<div class="flex w-max animate-marquee gap-8 px-4">
			{
				[...allItems, ...allItems].map((item) => (
					<span class="flex items-center gap-2 whitespace-nowrap">
						{item.icon && <TechIcon slug={item.icon} label={item.name} class="size-6" />}
						<span class="font-mono text-sm text-fg/80">{item.name}</span>
					</span>
				))
			}
		</div>
	</div>

	<div class="mt-6 grid gap-6 sm:grid-cols-2">
		{
			skills.map((group) => (
				<div class="rounded-lg border border-border bg-card p-5">
					<h3 class="text-sm font-medium text-fg">{group.group}</h3>
					<ul class="mt-3 flex flex-wrap gap-2">
						{group.items.map((item) => (
							<li class="flex items-center gap-2 rounded-md border border-border bg-muted px-2 py-1">
								{item.icon && <TechIcon slug={item.icon} label={item.name} class="size-5" />}
								<span class="font-mono text-xs text-fg/90">{item.name}</span>
							</li>
						))}
					</ul>
				</div>
			))
		}
	</div>
</section>
