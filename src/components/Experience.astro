---
import { experience, additionalExperience } from '../data/experience';
import { techIconMap } from '../data/skills';
import LogoAvatar from './LogoAvatar.astro';
import TechIcon from './icons/TechIcon.astro';
---

<section id="experiencia" class="reveal mx-auto max-w-5xl px-6 py-16">
	<h2 class="font-mono text-sm text-accent-2">03. Experiencia</h2>

	<ol class="mt-6 space-y-8 border-l border-border pl-6">
		{
			experience.map((entry) => (
				<li class="relative">
					<span class="absolute -left-[29px] top-1.5 h-2.5 w-2.5 rounded-full bg-primary" />
					<div class="flex items-start gap-3">
						<LogoAvatar name={entry.company} logo={entry.logo} size="size-10" class="mt-0.5" />
						<div>
							<p class="font-mono text-xs text-muted-fg">{entry.period}</p>
							<h3 class="mt-1 text-lg font-medium text-fg">{entry.role}</h3>
							<p class="text-sm text-muted-fg">{entry.company}</p>
						</div>
					</div>
					<p class="mt-3 text-fg/90">{entry.summary}</p>
					{entry.stack && (
						<div class="mt-3 flex flex-wrap gap-2">
							{entry.stack.map((tech) => (
								<span class="flex items-center gap-1.5 rounded-md border border-border bg-muted px-2 py-0.5">
									{techIconMap[tech] && (
										<TechIcon slug={techIconMap[tech]} label={tech} class="size-4" />
									)}
									<span class="font-mono text-xs text-fg/80">{tech}</span>
								</span>
							))}
						</div>
					)}
				</li>
			))
		}
	</ol>

	<p class="mt-8 text-sm text-muted-fg">{additionalExperience}</p>
</section>
