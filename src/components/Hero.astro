---
import { site } from '../data/site';
---

<section id="top" class="relative overflow-hidden px-6 pb-20 pt-16 md:pt-28">
	<div
		class="pointer-events-none absolute -top-24 right-0 -z-10 h-72 w-72 rounded-full bg-primary/20 blur-3xl"
	>
	</div>
	<div
		class="pointer-events-none absolute -left-10 top-32 -z-10 h-72 w-72 rounded-full bg-accent-2/20 blur-3xl"
	>
	</div>

	<div class="mx-auto max-w-5xl">
		<p
			class="animate-[fade-up_0.6s_ease-out_backwards] font-mono text-sm text-accent-2"
		>
			Hola, soy
		</p>

		<h1
			class="text-gradient mt-3 animate-[fade-up_0.6s_ease-out_0.05s_backwards] text-4xl font-semibold tracking-tight md:text-6xl"
		>
			{site.name}
		</h1>

		<p
			class="mt-4 max-w-2xl animate-[fade-up_0.6s_ease-out_0.1s_backwards] text-lg text-muted-fg md:text-xl"
		>
			{site.role}
		</p>

		<p
			class="mt-6 max-w-xl animate-[fade-up_0.6s_ease-out_0.15s_backwards] text-balance text-fg/90"
		>
			{site.tagline}
		</p>

		<div class="mt-8 flex animate-[fade-up_0.6s_ease-out_0.2s_backwards] flex-wrap gap-3">
			<a
				href="#experiencia"
				class="rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-fg transition-transform hover:scale-[1.02]"
			>
				Ver experiencia
			</a>
			<a
				href={site.github}
				target="_blank"
				rel="noopener noreferrer"
				class="rounded-md border border-border px-4 py-2 text-sm text-fg transition-colors hover:border-accent-2 hover:text-accent-2"
			>
				GitHub
			</a>
			<a
				href={site.linkedin}
				target="_blank"
				rel="noopener noreferrer"
				class="rounded-md border border-border px-4 py-2 text-sm text-fg transition-colors hover:border-accent-2 hover:text-accent-2"
			>
				LinkedIn
			</a>
		</div>
	</div>
</section>
