---
import { site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="border-t border-border/60">
	<div
		class="mx-auto flex max-w-5xl flex-col gap-2 px-6 py-8 text-sm text-muted-fg md:flex-row md:items-center md:justify-between"
	>
		<p>© {year} {site.name}</p>
		<div class="flex gap-4">
			<a href="/blog" class="hover:text-accent-2">Blog</a>
			<a href={site.github} target="_blank" rel="noopener noreferrer" class="hover:text-accent-2">
				GitHub
			</a>
			<a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-accent-2">
				LinkedIn
			</a>
			<a href={`mailto:${site.email}`} class="hover:text-accent-2">Email</a>
		</div>
	</div>
</footer>
